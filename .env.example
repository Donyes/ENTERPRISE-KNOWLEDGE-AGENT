APP_NAME=Enterprise Knowledge Agent
APP_ENV=development

# Chat model configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Embedding model configuration
EMBEDDING_PROVIDER=qwen
EMBEDDING_API_KEY=your_dashscope_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

# Chroma vector store
CHROMA_PERSIST_DIRECTORY=data/vectorstore/chroma
CHROMA_COLLECTION_NAME=enterprise_knowledge_base

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=enterprise-knowledge-agent